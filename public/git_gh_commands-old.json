[
  {
    "category": "Setup & Config",
    "commands": [
      {
        "name": "git init",
        "description": "Create an empty Git repository or reinitialize an existing one",
        "usage": "git init [directory]"
      },
      {
        "name": "git clone",
        "description": "Clone a repository into a new directory",
        "usage": "git clone <url> [directory]"
      },
      {
        "name": "git config",
        "description": "Get or set repository or global options",
        "usage": "git config [--global] <key> <value>"
      }
    ]
  },
  {
    "category": "Staging & Snapshots",
    "commands": [
      {
        "name": "git status",
        "description": "Show the working tree status",
        "usage": "git status [-s]"
      },
      {
        "name": "git add",
        "description": "Add file contents to the staging area",
        "usage": "git add <file|.>"
      },
      {
        "name": "git commit",
        "description": "Record changes to the repository",
        "usage": "git commit -m \"<message>\""
      },
      {
        "name": "git diff",
        "description": "Show changes between commits, working tree, etc.",
        "usage": "git diff [--staged] [file]"
      },
      {
        "name": "git reset",
        "description": "Unstage files or reset to a previous commit",
        "usage": "git reset [--soft|--mixed|--hard] [commit]"
      },
      {
        "name": "git rm",
        "description": "Remove files from the working tree and staging area",
        "usage": "git rm [--cached] <file>"
      },
      {
        "name": "git stash",
        "description": "Stash changes in the working directory",
        "usage": "git stash [push -m \"<message>\"] | pop | list | drop"
      }
    ]
  },
  {
    "category": "Branching & Merging",
    "commands": [
      {
        "name": "git branch",
        "description": "List, create, or delete branches",
        "usage": "git branch [-d|-D] [name]"
      },
      {
        "name": "git checkout",
        "description": "Switch branches or restore working tree files",
        "usage": "git checkout [-b] <branch|file>"
      },
      {
        "name": "git switch",
        "description": "Switch to a branch",
        "usage": "git switch [-c] <branch>"
      },
      {
        "name": "git merge",
        "description": "Join two or more development histories together",
        "usage": "git merge [--no-ff] <branch>"
      },
      {
        "name": "git rebase",
        "description": "Reapply commits on top of another base tip",
        "usage": "git rebase [-i] <branch>"
      },
      {
        "name": "git cherry-pick",
        "description": "Apply the changes introduced by existing commits",
        "usage": "git cherry-pick <commit>"
      }
    ]
  },
  {
    "category": "Remote",
    "commands": [
      {
        "name": "git remote",
        "description": "Manage set of tracked repositories",
        "usage": "git remote add|remove|rename <name> [url]"
      },
      {
        "name": "git fetch",
        "description": "Download objects and refs from a remote",
        "usage": "git fetch [remote] [branch]"
      },
      {
        "name": "git pull",
        "description": "Fetch from remote and integrate with local branch",
        "usage": "git pull [--rebase] [remote] [branch]"
      },
      {
        "name": "git push",
        "description": "Update remote refs along with associated objects",
        "usage": "git push [-u] [remote] [branch]"
      }
    ]
  },
  {
    "category": "Inspection & History",
    "commands": [
      {
        "name": "git log",
        "description": "Show commit logs",
        "usage": "git log [--oneline] [--graph] [-n <count>]"
      },
      {
        "name": "git show",
        "description": "Show information about a Git object",
        "usage": "git show [commit|tag]"
      },
      {
        "name": "git blame",
        "description": "Show who last modified each line of a file",
        "usage": "git blame <file>"
      },
      {
        "name": "git reflog",
        "description": "Show a log of all reference updates",
        "usage": "git reflog [show] [branch]"
      },
      {
        "name": "git shortlog",
        "description": "Summarize git log output by author",
        "usage": "git shortlog [-s] [-n]"
      }
    ]
  },
  {
    "category": "Undoing Changes",
    "commands": [
      {
        "name": "git restore",
        "description": "Restore working tree or staging area files",
        "usage": "git restore [--staged] <file>"
      },
      {
        "name": "git revert",
        "description": "Create a new commit that undoes a previous commit",
        "usage": "git revert <commit>"
      },
      {
        "name": "git clean",
        "description": "Remove untracked files from the working tree",
        "usage": "git clean [-f] [-d] [-n]"
      }
    ]
  },
  {
    "category": "Tags",
    "commands": [
      {
        "name": "git tag",
        "description": "Create, list, or delete tags",
        "usage": "git tag [-a] <tagname> [-m \"<message>\"]"
      },
      {
        "name": "git push --tags",
        "description": "Push all tags to remote",
        "usage": "git push [remote] --tags"
      }
    ]
  },
  {
    "category": "Submodules",
    "commands": [
      {
        "name": "git submodule add",
        "description": "Add a repository as a submodule",
        "usage": "git submodule add <url> [path]"
      },
      {
        "name": "git submodule update",
        "description": "Update registered submodules",
        "usage": "git submodule update [--init] [--recursive]"
      },
      {
        "name": "git submodule status",
        "description": "Show the status of submodules",
        "usage": "git submodule status"
      }
    ]
  },
  {
