        "usage": "gh repo create [name] [--public|--private] [--clone]"
      },
      {
        "name": "gh repo clone",
        "description": "Clone a repository locally",
        "usage": "gh repo clone <owner/repo>"
      },
      {
        "name": "gh repo fork",
        "description": "Fork a repository",
        "usage": "gh repo fork [repo] [--clone]"
      },
      {
        "name": "gh repo view",
        "description": "View repository details",
        "usage": "gh repo view [repo] [--web]"
      },
      {
        "name": "gh repo list",
        "description": "List repositories for a user or org",
        "usage": "gh repo list [owner] [--limit <n>]"
      },
      {
        "name": "gh repo delete",
        "description": "Delete a repository",
        "usage": "gh repo delete <repo> [--yes]"
      }
    ]
  },
  {
    "category": "gh pr",
    "commands": [
      {
        "name": "gh pr create",
        "description": "Create a pull request",
        "usage": "gh pr create [--title <t>] [--body <b>] [--draft]"
      },
      {
        "name": "gh pr list",
        "description": "List pull requests in a repository",
        "usage": "gh pr list [--state <open|closed|merged>]"
      },
      {
        "name": "gh pr view",
        "description": "View a pull request",
        "usage": "gh pr view [<number>|<url>|<branch>] [--web]"
      },
      {
        "name": "gh pr checkout",
        "description": "Check out a pull request locally",
        "usage": "gh pr checkout <number|url|branch>"
      },
      {
        "name": "gh pr merge",
        "description": "Merge a pull request",
        "usage": "gh pr merge [<number>] [--squash|--rebase|--merge]"
      },
      {
        "name": "gh pr diff",
        "description": "View changes in a pull request",
        "usage": "gh pr diff [<number>]"
      },
      {
        "name": "gh pr close",
        "description": "Close a pull request",
        "usage": "gh pr close <number>"
      }
    ]
  },
  {
    "category": "gh issue",
    "commands": [
      {
        "name": "gh issue create",
