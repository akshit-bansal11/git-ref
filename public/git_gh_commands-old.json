        "usage": "gh issue create [--title <t>] [--body <b>] [--label <l>]"
      },
      {
        "name": "gh issue list",
        "description": "List issues in a repository",
        "usage": "gh issue list [--state <open|closed>] [--label <l>]"
      },
      {
        "name": "gh issue view",
        "description": "View an issue",
        "usage": "gh issue view <number> [--web]"
      },
      {
        "name": "gh issue close",
        "description": "Close an issue",
        "usage": "gh issue close <number>"
      },
      {
        "name": "gh issue comment",
        "description": "Add a comment to an issue",
        "usage": "gh issue comment <number> --body <body>"
      }
    ]
  },
  {
    "category": "gh workflow & run",
    "commands": [
      {
        "name": "gh workflow list",
