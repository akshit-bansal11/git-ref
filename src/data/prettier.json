                },
                {
                    "command": "prettier --write . --html-whitespace-sensitivity=strict",
                    "description": "Treat all whitespace as significant in HTML formatting"
                },
                {
                    "command": "prettier --write . --html-whitespace-sensitivity=ignore",
                    "description": "Ignore all whitespace sensitivity in HTML formatting"
                },
                {
                    "command": "prettier --write . --vue-indent-script-and-style",
                    "description": "Indent script and style blocks inside Vue single-file components"
                },
                {
                    "command": "prettier --write . --no-vue-indent-script-and-style",
                    "description": "Do not indent script and style blocks inside Vue single-file components"
                },
                {
                    "command": "prettier --write . --end-of-line=lf",
                    "description": "Format files using LF line endings"
                },
                {
                    "command": "prettier --write . --end-of-line=crlf",
                    "description": "Format files using CRLF line endings"
