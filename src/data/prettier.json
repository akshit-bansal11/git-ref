                },
                {
                    "command": "prettier --write . --arrow-parens=avoid",
                    "description": "Omit parentheses around single arrow function arguments when possible"
                },
                {
                    "command": "prettier --write . --prose-wrap=always",
                    "description": "Wrap prose in Markdown and similar files at the print width"
                },
                {
                    "command": "prettier --write . --prose-wrap=never",
                    "description": "Do not wrap prose in Markdown files regardless of line length"
                },
                {
                    "command": "prettier --write . --prose-wrap=preserve",
