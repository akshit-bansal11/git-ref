                },
                {
                    "command": "prettier --check . --no-error-on-unmatched-pattern",
                    "description": "Check formatting without failing if a glob pattern matches no files"
                },
                {
                    "command": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\" --ignore-path .gitignore --log-level=warn",
