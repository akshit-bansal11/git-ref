                    "command": "prettier --write . --trailing-comma=es5",
                    "description": "Add trailing commas only where valid in ES5 syntax"
                },
                {
                    "command": "prettier --write . --trailing-comma=none",
                    "description": "Remove all trailing commas from formatted output"
                },
                {
                    "command": "prettier --write . --no-semi",
