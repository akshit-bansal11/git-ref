{
    "name": "Prettier",
    "slug": "prettier",
    "logo": "https://svgl.app/library/prettier-icon-light.svg",
    "accent": "#e94560",
    "description": "Opinionated code formatter supporting multiple languages",
    "categories": [
        {
            "title": "Formatting Files",
            "commands": [
                {
                    "command": "prettier --write .",
                    "description": "Format all supported files in the current directory recursively"
                },
                {
                    "command": "prettier --write src",
                    "description": "Format all supported files in the src directory recursively"
                },
                {
                    "command": "prettier --write src/index.ts",
                    "description": "Format a single specific file in place"
                },
                {
                    "command": "prettier --write \"src/**/*.ts\"",
                    "description": "Format all TypeScript files in src recursively"
                },
                {
                    "command": "prettier --write \"src/**/*.{ts,tsx}\"",
                    "description": "Format all TypeScript and TSX files in src recursively"
                },
                {
                    "command": "prettier --write \"**/*.{js,jsx,ts,tsx}\"",
                    "description": "Format all JS and TS files across the entire project"
                },
                {
                    "command": "prettier --write \"**/*.{js,ts,json,css,md}\"",
                    "description": "Format JS, TS, JSON, CSS, and Markdown files across the project"
                },
                {
                    "command": "prettier --write \"src/**\" \"tests/**\"",
                    "description": "Format all files in both src and tests directories"
                },
                {
                    "command": "prettier --write . --ignore-path .gitignore",
                    "description": "Format all files using .gitignore as the ignore rule source"
                },
                {
                    "command": "prettier --write . --ignore-path .prettierignore",
                    "description": "Format all files using a specific .prettierignore file"
                },
                {
                    "command": "prettier --write . --ignore-unknown",
                    "description": "Format supported files, silently skipping unsupported file types"
                },
                {
                    "command": "prettier --write . --no-error-on-unmatched-pattern",
                    "description": "Format files without erroring if a glob pattern matches nothing"
                },
                {
                    "command": "prettier --write . --log-level=warn",
                    "description": "Format files showing only warnings and errors in output"
                },
                {
                    "command": "prettier --write . --log-level=silent",
                    "description": "Format files suppressing all output"
                },
                {
                    "command": "prettier --write . --log-level=debug",
                    "description": "Format files with verbose debug output for troubleshooting"
                }
            ]
        },
        {
            "title": "Checking Files",
            "commands": [
                {
                    "command": "prettier --check .",
                    "description": "Check if all supported files in the current directory are formatted"
                },
                {
                    "command": "prettier --check src",
                    "description": "Check if all supported files in the src directory are formatted"
                },
                {
                    "command": "prettier --check src/index.ts",
                    "description": "Check if a single specific file is formatted correctly"
                },
                {
                    "command": "prettier --check \"src/**/*.ts\"",
                    "description": "Check if all TypeScript files in src are formatted"
                },
                {
                    "command": "prettier --check \"**/*.{js,ts,json,css,md}\"",
                    "description": "Check formatting of JS, TS, JSON, CSS, and Markdown files"
                },
                {
                    "command": "prettier --check . --ignore-path .gitignore",
                    "description": "Check formatting of files using .gitignore as the ignore source"
                },
                {
                    "command": "prettier --check . --ignore-unknown",
                    "description": "Check formatting, silently skipping unsupported file types"
                },
                {
                    "command": "prettier --check . --log-level=warn",
                    "description": "Check formatting showing only warnings and errors"
                }
            ]
        },
        {
            "title": "Printing & Stdout",
            "commands": [
                {
                    "command": "prettier src/index.ts",
                    "description": "Print the formatted output of a file to stdout without writing it"
                },
                {
                    "command": "prettier --stdin-filepath src/index.ts",
                    "description": "Format stdin input treating it as the given file path and print to stdout"
                },
                {
                    "command": "cat src/index.ts | prettier --stdin-filepath index.ts",
                    "description": "Pipe a file through prettier via stdin and print formatted output"
                },
                {
                    "command": "prettier src/index.ts --write=false",
                    "description": "Explicitly print formatted output to stdout without writing to disk"
                }
            ]
        },
